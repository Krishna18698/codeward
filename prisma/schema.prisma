generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth (NextAuth) ───────────────────────────────────────────────────────

model User {
  id              String    @id @default(cuid())
  name            String?
  email           String?   @unique
  emailVerified   DateTime?
  image           String?
  password        String?
  experienceLevel String?   // JUNIOR | MID | SENIOR
  targetCompany   String?   // e.g. "Meta", "Google"
  onboarded       Boolean   @default(false)

  accounts            Account[]
  sessions            Session[]
  problemStatuses     UserProblemStatus[]
  notes               UserNote[]
  chatMessages        ChatMessage[]
  customSheets        Sheet[]
  conversations       MentorConversation[]
  reviewAttempts      ReviewAttempt[]
  bugHuntAttempts     BugHuntAttempt[]
  buildItAttempts     BuildItAttempt[]
}

// ─── Code Review practice mode ─────────────────────────────────────────────
// Exercises live as content-as-code (src/content/code-reviews); only the
// user's graded attempts are persisted.
model ReviewAttempt {
  id           String   @id @default(cuid())
  userId       String
  exerciseSlug String
  comments     String   @db.Text
  score        Int
  caught       Json
  missed       Json
  feedback     String   @db.Text
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, exerciseSlug])
}

// ─── Bug Hunt practice mode ────────────────────────────────────────────────
model BugHuntAttempt {
  id           String   @id @default(cuid())
  userId       String
  exerciseSlug String
  diagnosis    String   @db.Text
  score        Int
  rootCaught   Boolean
  fixReasonable Boolean
  feedback     String   @db.Text
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, exerciseSlug])
}

// ─── Build It practice mode (staged LLD) ───────────────────────────────────
// One row per stage submission — never mutated. "Highest unlocked stage" and
// "best score per stage" are both derived from this table (groupBy), same as
// Code Review and Bug Hunt — no separate progress table.
model BuildItAttempt {
  id             String   @id @default(cuid())
  userId         String
  problemSlug    String
  stage          Int
  language       String   // "csharp" | "python" | "kotlin"
  approach       String   @db.Text
  explanation    String   @db.Text
  score          Int
  criteria       Json
  invariantHolds Boolean?
  feedback       String   @db.Text
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, problemSlug, stage])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── DSA Sheets & Problems ────────────────────────────────────────────────

enum SheetSource {
  BLIND75
  STRIVERS
  CUSTOM
  TOP300
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum ProblemPattern {
  ARRAYS
  STRINGS
  LINKED_LIST
  TREES
  GRAPHS
  DYNAMIC_PROGRAMMING
  BACKTRACKING
  BINARY_SEARCH
  SLIDING_WINDOW
  TWO_POINTERS
  STACK_QUEUE
  HEAP
  TRIE
  MATH
  BIT_MANIPULATION
  OTHER
}

model Sheet {
  id        String      @id @default(cuid())
  name      String
  source    SheetSource @default(CUSTOM)
  isPreset  Boolean     @default(false)
  userId    String?     // null for preset sheets
  createdAt DateTime    @default(now())

  user     User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  problems Problem[]
}

model Problem {
  id          String         @id @default(cuid())
  title       String
  description String         @db.Text
  difficulty  Difficulty
  pattern     ProblemPattern
  leetcodeUrl String?
  gfgUrl      String?
  mustDo      Boolean        @default(false)
  order       Int            @default(0)
  sheetId     String
  companies   String[]       @default([])

  sheet       Sheet               @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  testCases   TestCase[]
  statuses    UserProblemStatus[]
  notes       UserNote[]
}

model TestCase {
  id             String  @id @default(cuid())
  problemId      String
  input          String  @db.Text
  expectedOutput String  @db.Text
  isHidden       Boolean @default(false)

  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)
}

enum ProblemStatus {
  TODO
  SOLVING
  DONE
}

model UserProblemStatus {
  id        String        @id @default(cuid())
  userId    String
  problemId String
  status    ProblemStatus @default(TODO)
  toRevise  Boolean       @default(false)
  updatedAt DateTime      @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([userId, problemId])
}

// ─── System Design ────────────────────────────────────────────────────────

enum ExperienceLevel {
  JUNIOR
  MID
  SENIOR
}

model SystemDesignQuestion {
  id              String          @id @default(cuid())
  title           String
  description     String          @db.Text
  difficulty      Difficulty
  mustDo          Boolean         @default(false)
  experienceLevel ExperienceLevel
  order           Int             @default(0)

  notes UserNote[]
}

// ─── Notes ────────────────────────────────────────────────────────────────

model UserNote {
  id          String   @id @default(cuid())
  userId      String
  content     String   @db.Text
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  problemId   String?
  sdQuestionId String?

  user       User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem    Problem?              @relation(fields: [problemId], references: [id], onDelete: SetNull)
  sdQuestion SystemDesignQuestion? @relation(fields: [sdQuestionId], references: [id], onDelete: SetNull)
}

// ─── RAG Knowledge Base ───────────────────────────────────────────────────

model KnowledgeChunk {
  id        String   @id @default(cuid())
  content   String   @db.Text
  source    String   // e.g. "dsa:arrays", "sd:url-shortener", "pattern:trees"
  title     String
  embedding Unsupported("vector(512)")?
  createdAt DateTime @default(now())
}

// ─── AI Mentor Chat ───────────────────────────────────────────────────────

enum ChatRole {
  USER
  ASSISTANT
}

model MentorConversation {
  id        String        @id @default(cuid())
  userId    String
  title     String        @default("New conversation")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  ChatMessage[]
}

model ChatMessage {
  id             String              @id @default(cuid())
  userId         String
  conversationId String?
  role           ChatRole
  content        String              @db.Text
  messageType    String              @default("text")
  sheetId        String?
  sheetName      String?
  problemCount   Int?
  rationale      String?
  context        String?
  createdAt      DateTime            @default(now())

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation MentorConversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
}
