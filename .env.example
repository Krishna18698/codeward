# ══════════════════════════════════════════════════════════════════
#  PrepArc — Environment Variables
#  Copy this file to .env.local and fill in your values.
# ══════════════════════════════════════════════════════════════════

# ── 1. Database (Required) ─────────────────────────────────────────
# Neon PostgreSQL with pgvector extension enabled.
# Steps:
#   1. Go to https://neon.tech → Sign up → New Project
#   2. Enable the pgvector extension: run `CREATE EXTENSION vector;` in the SQL editor
#   3. Copy the "Pooled connection" string from the Dashboard → Connection Details
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require&channel_binding=require"

# ── 2. NextAuth (Required) ─────────────────────────────────────────
# NEXTAUTH_URL: your app's base URL — no trailing slash.
#   - Local dev:    http://localhost:3000
#   - Mobile dev:   use ngrok (see Google OAuth note below)
#   - Production:   https://yourdomain.com
# NEXTAUTH_SECRET: run `openssl rand -base64 32` in your terminal
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# ── 3. Google OAuth (Required) ─────────────────────────────────────
# Steps:
#   1. Go to https://console.cloud.google.com → APIs & Services → Credentials
#   2. Create OAuth 2.0 Client ID → Web application
#   3. Add Authorized redirect URI: <NEXTAUTH_URL>/api/auth/callback/google
#      e.g. http://localhost:3000/api/auth/callback/google
#   Note: Google rejects raw IPs and localhost on mobile.
#         Use ngrok (https://ngrok.com) for mobile testing and add the
#         ngrok URL as an authorized redirect URI in the console.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── 4. Groq AI — LLM (Required) ────────────────────────────────────
# Powers: AI Mentor chat, answer evaluation, custom sheet generation.
# Steps:
#   1. Go to https://console.groq.com → Sign up (free)
#   2. API Keys → Create new key
GROQ_API_KEY=""

# ── 5. Voyage AI — Embeddings (Required) ───────────────────────────
# Powers: RAG semantic search in AI Mentor (matches questions to knowledge base).
# Steps:
#   1. Go to https://dash.voyageai.com → Sign up (free tier available)
#   2. API Keys → Create new key
# After setting this, seed the knowledge base once:
#   curl -X POST <NEXTAUTH_URL>/api/mentor/ingest \
#     -H "Content-Type: application/json" \
#     -d '{"secret":"<INGEST_SECRET>"}'
VOYAGE_API_KEY=""

# ── 6. Ingest Secret (Required) ────────────────────────────────────
# Protects the /api/mentor/ingest endpoint so only you can trigger it.
# Set to any strong random string — run `openssl rand -base64 24`
INGEST_SECRET=""

# ── 7. Upstash Redis — Rate Limiting (Optional) ────────────────────
# Rate-limits AI Mentor chat (30/min), sheet generation (5/hr), sign-up (5/hr),
# code execution (8/hr per user), and holds the shared daily exec budget.
# Skipped silently in local dev if not set — only needed for production.
# Steps:
#   1. Go to https://console.upstash.com → Create Database → REST API
#   2. Copy the REST URL and REST Token
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ── 8. JDoodle — Code Execution (Optional) ─────────────────────────
# Powers "Run tests" in Bug Hunt and Build It (real code execution).
# FREE TIER = 20 credits/day, SHARED across the whole app. Skipped silently if
# not set — those modes fall back to LLM-only grading (fully functional).
# Steps:
#   1. Go to https://www.jdoodle.com → Sign up → Compiler API → get credentials
#   2. Copy the Client ID and Client Secret
JDOODLE_CLIENT_ID=""
JDOODLE_CLIENT_SECRET=""
# Optional: internal daily cap, kept below JDoodle's real 20/day for headroom.
# EXEC_DAILY_BUDGET="18"
